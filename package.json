{
  "name": "shipping-backend",
  "version": "1.0.0",
  "description": "UQMS backend API with Node.js, TypeScript, MongoDB",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node dist/server.js",
    "dev:local": "ts-node-dev --respawn --transpile-only src/server.ts",
    "prebuild": "npm ci --include=dev",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node src/seed.ts",
    "seed:operations": "ts-node src/seedOperations.ts",
    "seed:vessel-codes": "ts-node src/seedVesselCodes.ts",
    "seed:rec-equip-ques": "ts-node src/seedRecEquipQues.ts",
    "seed:hr": "ts-node src/seedHr.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1051.0",
    "@aws-sdk/s3-request-presigner": "^3.1051.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.14.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.12.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
